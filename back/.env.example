# Backend Environment Variables (Render)

# Hugging Face Spaces URL for ML processing
HUGGINGFACE_SPACE_URL=https://your-username-your-space-name.hf.space

# Supabase (Track Library - service role for backend processing)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Free-tier tuning knobs for the Hugging Face Space
# Lower bitrate saves Supabase storage and transfer. Raise for better stem quality.
LIBRARY_STEM_BITRATE=80k

# Shorter chunks lower peak memory on CPU, but can increase total processing time.
DEMUCS_SEGMENT_SECONDS=8.0
DEMUCS_OVERLAP_SECONDS=0.5
TORCH_CPU_THREADS=2

# Metadata analysis uses a bounded mono preview to save CPU.
ANALYSIS_SAMPLE_RATE=22050
ANALYSIS_MAX_SECONDS=180
ANALYSIS_USE_HPSS=false
